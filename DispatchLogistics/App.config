<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <!--
      Строка подключения к базе данных SQL Server.
      
      Параметры:
        Data Source    — имя или адрес экземпляра SQL Server
                         "." означает локальный сервер по умолчанию
                         Можно заменить на ".\SQLEXPRESS" для Express-версии
                         или на "SERVERNAME\INSTANCE" для удалённого сервера
                         
        Initial Catalog — имя базы данных
        Integrated Security=True — используется Windows-аутентификация
        
      Если у вас SQL Server с именем экземпляра, измените Data Source:
        Data Source=.\SQLEXPRESS
    -->
    <add name="DispatchLogisticsDB" 
         connectionString="Data Source=.;Initial Catalog=DispatchLogisticsDB;Integrated Security=True;Connect Timeout=30;" 
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  
  <appSettings>
    <!-- Название приложения -->
    <add key="AppName" value="Диспетчерская логистика: Заказы и тарифы" />
    <add key="AppVersion" value="1.0.0" />
  </appSettings>
  
  <startup>
    <!-- Требуется .NET Framework 4.7.2 (совместимо с VS 2019) -->
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
</configuration>
